{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "normalize-avatars": "python scripts/normalize_avatar_circles.py --apply",
    "normalize-avatars-galactic": "python scripts/normalize_avatar_circles.py --apply --only artifacts/astrobot/public/avatar-presets/miss-galactica/*.webp",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test:e2e:smoke": "node scripts/e2e/smoke-chat-billing.mjs",
    "diagnostics:api": "node scripts/diagnostics/api-health.mjs"
  },
  "private": true,
  "devDependencies": {
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.3.0"
  }
}
